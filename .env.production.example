# Copy this file to .env.production before starting the production stack.

# Django
SECRET_KEY=replace-with-a-long-random-secret
DJANGO_SETTINGS_MODULE=gatepass.settings.production

# Database
DB_NAME=gatepass
DB_USER=gatepass
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend / URLs
FRONTEND_URL=https://gatepass.example.com
VITE_API_URL=/api/v1

# Security
ALLOWED_HOSTS=gatepass.example.com
CORS_ALLOWED_ORIGINS=https://gatepass.example.com
CSRF_TRUSTED_ORIGINS=https://gatepass.example.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@gatepass.example.com

# SMS
SMS_BACKEND=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
